{
  "name": "rediswall",
  "version": "0.1.0",
  "description": "Distributed rate limiting framework for Express — sliding window, token bucket, circuit breaker, multi-tier",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "benchmark": "ts-node benchmark/run.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["rate-limiter", "redis", "express", "middleware", "sliding-window", "circuit-breaker"],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0",
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {},
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}